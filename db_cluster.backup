--
-- Name: workouts Users can create their own workouts; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can create their own workouts" ON public.workouts FOR INSERT WITH CHECK ((auth.uid() = user_id));


--
-- Name: habit_logs Users can delete their own habit logs; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can delete their own habit logs" ON public.habit_logs FOR DELETE USING ((auth.uid() = ( SELECT habits.user_id
   FROM public.habits
  WHERE (habits.id = habit_logs.habit_id))));


